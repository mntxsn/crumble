{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "version": "2.0.0",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "crumble@mntxsn.github.io",
      "strict_min_version": "113.0"
    },
    "gecko_android": {
      "strict_min_version": "113.0"
    }
  },
  "author": "mntxsn and contributors",
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "declarativeNetRequestWithHostAccess",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "data/background.js",
    "scripts": ["data/background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "data/options.html"
  },
  "action": {
    "default_popup": "data/menu/index.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    }
  },
  "commands": {
    "toggle-whitelist": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "__MSG_commandToggleWhitelist__"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
